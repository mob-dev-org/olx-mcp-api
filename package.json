{
  "name": "olx-pik-toolkit",
  "version": "0.1.0",
  "description": "Interni CLI i MCP server za upravljanje OLX.ba / PIK.ba shopovima",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "olx": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "mcp": "node dist/mcp/server.js",
    "dev:cli": "tsc && node dist/cli/index.js",
    "dev:mcp": "tsc && node dist/mcp/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0"
  }
}
