# Bazni URL API-ja. Uz rebrand olx.ba -> pik.ba moguce je da se promijeni u https://api.pik.ba
OLX_BASE_URL=https://api.olx.ba

# Preporuceni nacin: vec dobijen Bearer token (po korisniku). Ako je postavljen, login se preskace.
OLX_TOKEN=

# Alternativa: login kredencijalima (token se onda dobije pozivom auth login).
# NE commitati pravi .env u git.
OLX_USERNAME=
OLX_PASSWORD=
OLX_DEVICE_NAME=olx_pik_toolkit

# Alternativa: stari tokeni (ako nemas pristup lozinki)
OLX_CLIENT_ID=
OLX_CLIENT_TOKEN=

# Konzervativni throttling (ms izmedju zahtjeva) i broj pokusaja
OLX_MIN_REQUEST_INTERVAL_MS=350
OLX_MAX_RETRIES=4
OLX_TIMEOUT_MS=20000

# =====================================================================
# VISE KLIJENATA (PROFILI) - vise OLX tokena u jednom .env
# =====================================================================
# Pravi tokeni idu OVDJE, u .env (koji je u .gitignore). Ovaj .env.example
# pokazuje samo KAKO imenovati varijable; ne stavljaj prave tokene u njega.
#
# Konvencija: svaki klijent je jedna varijabla oblika OLX_TOKEN_<IME>.
# <IME> postaje ime profila (malim slovima). Tako npr:
#
#   OLX_TOKEN_AUTOCENTAR=bearer_token_klijenta_autocentar
#   OLX_TOKEN_TEHNOMARKET=bearer_token_klijenta_tehnomarket
#   OLX_TOKEN_MOJSHOP=bearer_token_naseg_shopa
#
# daje profile: autocentar, tehnomarket, mojshop.
#
# Koristenje:
# - CLI:  node dist/cli/index.js --profile autocentar listings ls --all
# - MCP:  alat olx_switch_account (profile: "autocentar") za jedan server,
#         ili pokreni server sa OLX_PROFILE=autocentar.
# - Lista profila: node dist/cli/index.js auth profiles  (ili MCP olx_list_accounts)
#
# Dodavanje novog klijenta = samo dopisi novu OLX_TOKEN_<IME> liniju u .env.

# Aktivni profil ako nije zadat --profile (opciono):
OLX_PROFILE=

# Alternativa env varijablama: JSON fajl sa profilima (default .olx-profiles.json):
# OLX_PROFILES_FILE=.olx-profiles.json
